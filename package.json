{
  "name": "incident-platform",
  "devDependencies": {
    "concurrently": "^9.2.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3"
  },
  "lint-staged": {
    "**/*.{js,jsx,ts,tsx}": [
      "prettier --write"
    ],
    "**/*.{json,md,css}": [
      "prettier --write"
    ]
  },
  "private": true,
  "scripts": {
    "dev": "concurrently -n frontend,backend -c green,cyan \"bun --filter frontend dev\" \"bun --filter backend dev\"",
    "prepare": "husky"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "date-fns": "^4.1.0",
    "framer-motion": "^12.38.0",
    "resend": "^6.12.2"
  }
}
